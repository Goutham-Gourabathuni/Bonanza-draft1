{
  "name": "bananawebsite",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start-frontend": "cd frontend && npm start",
    "start-backend": "cd api && uvicorn index:app --port 8000",
    "dev": "concurrently \"npm run start-frontend\" \"npm run start-backend\"",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}